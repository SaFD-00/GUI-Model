HF_TOKEN=your_huggingface_token_here
# NPROC_PER_NODE: node 당 GPU 수 (= torchrun world size, single node 기준). 기본값 2.
# gui-model.ipynb Cell 6 (Section 0) 이 이 값을 읽어 gradient_accumulation_steps 를
# 자동 역계산한다:
#   global_batch = per_device * grad_accum * NPROC_PER_NODE  (= GLOBAL_BATCH_SIZE, 기본 64)
#   grad_accum   = 64 / (per_device * NPROC_PER_NODE)
# 64 가 (per_device * NPROC_PER_NODE) 로 나누어떨어지지 않으면 Cell 6 이 ValueError 로 중단된다.
NPROC_PER_NODE=2